{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Chunk Metadata Schema",
  "description": "Fixed metadata schema for each chunk stored in Qdrant",
  "type": "object",
  "required": [
    "doc_id",
    "file_name",
    "file_type",
    "department",
    "project",
    "visibility",
    "status",
    "chunk_index",
    "total_chunks",
    "text"
  ],
  "properties": {
    "doc_id":          { "type": "string", "description": "Auto-generated UUID" },
    "file_name":       { "type": "string", "description": "Original file name" },
    "file_type":       { "type": "string", "description": "File extension without dot" },
    "department":      { "type": "string", "description": "Department extracted from folder path" },
    "project":         { "type": "string", "description": "Project extracted from folder path" },
    "author":          { "type": "string", "default": "" },
    "created_at":      { "type": "string", "format": "date-time" },
    "category":        { "type": "string", "default": "" },
    "tags":            { "type": "array", "items": { "type": "string" }, "default": [] },
    "summary":         { "type": "string", "default": "" },
    "visibility":      { "type": "string", "enum": ["公开", "部门", "项目"], "default": "项目" },
    "status":          { "type": "string", "enum": ["draft", "active", "deprecated", "archived"], "default": "active" },
    "deprecated_reason": { "type": "string", "default": "" },
    "deprecated_at":   { "type": ["string", "null"], "format": "date-time", "default": null },
    "deprecated_by":   { "type": "string", "default": "" },
    "valid_from":      { "type": ["string", "null"], "format": "date", "default": null },
    "valid_until":     { "type": ["string", "null"], "format": "date", "default": null },
    "superseded_by":   { "type": ["string", "null"], "default": null },
    "chunk_index":     { "type": "integer", "minimum": 0 },
    "total_chunks":    { "type": "integer", "minimum": 1 },
    "text":            { "type": "string" },
    "image_refs":      { "type": "array", "items": { "type": "string" }, "default": [] }
  }
}
